# Maintainer: Philipp Wollermann <philipp@philwo.de>

# Example package for the [philwo] custom repo. Copy this directory to start a new
# package. It is fully self-contained: it builds nothing and downloads nothing, it
# just installs a small script and a license file.
pkgname=hello-philwo
pkgver=1.0.0
pkgrel=1
pkgdesc="Example package for philwo's custom Arch repo"
arch=('x86_64')
url="https://github.com/philwo/arch-repo"
license=('MIT')
depends=('bash')

package() {
	install -dm755 "${pkgdir}/usr/bin"
	cat > "${pkgdir}/usr/bin/hello-philwo" << EOF
#!/bin/bash
echo "Hello from philwo's custom Arch repo! (${pkgname} ${pkgver})"
EOF
	chmod 755 "${pkgdir}/usr/bin/hello-philwo"

	install -Dm644 /dev/stdin "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'EOF'
MIT License

Copyright (c) Philipp Wollermann

Permission is hereby granted, free of charge, to any person obtaining a copy of
this software and associated documentation files (the "Software"), to deal in
the Software without restriction. THE SOFTWARE IS PROVIDED "AS IS", WITHOUT
WARRANTY OF ANY KIND.
EOF
}
